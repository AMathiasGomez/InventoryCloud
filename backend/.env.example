# Copia este archivo como .env y rellena los valores.
# En Railway estas variables las provee el servicio MySQL (pestaña Variables).

# --- Conexión a MySQL ---
# Opción A: usar la URL completa que da Railway (recomendado)
# MYSQL_URL=mysql://root:password@host.proxy.rlwy.net:38472/railway

# Opción B: variables sueltas (equivalentes a las de Railway)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=inventorycloud

# --- Servidor ---
PORT=3000

# --- Autenticación ---
# Cambia esto por una cadena larga y aleatoria en producción.
JWT_SECRET=cambia-esta-clave-secreta
JWT_EXPIRES=8h

# Origen permitido para CORS (el dominio donde se sirve el frontend).
# Usa * para permitir cualquiera durante el desarrollo.
CORS_ORIGIN=*
